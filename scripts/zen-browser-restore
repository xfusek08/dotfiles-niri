#!/usr/bin/env zsh
#
# zen-browser-restore
#
# Restores Zen Browser profile data from a backup archive.
# The archive must be a .tar.gz created by zen-browser-backup.
#
# Usage:
#   zen-browser-restore <backup-file>
#
# Options:
#   --help    Show this help message

set -euo pipefail
SCRIPT_DIR="${0:A:h}"
source "$SCRIPT_DIR/zen-browser-lib"

if [[ "$#" -eq 0 || "$1" == "--help" ]]; then
    echo "Usage: zen-browser-restore <backup-file>"
    echo ""
    echo "Restores Zen Browser profile data from a backup archive."
    echo "The archive is extracted into the existing profile directory"
    echo "(~/.zen or ~/.config/zen, whichever is found)."
    exit 0
fi

BACKUP_FILE="$1"

[[ -f "$BACKUP_FILE" ]] || die "Backup file not found: $BACKUP_FILE"
[[ "$BACKUP_FILE" == *.tar.gz ]] || die "Expected a .tar.gz archive, got: $BACKUP_FILE"

PROFILE_DIR=$(zen_browser_detect_profile)

log -i "Restoring Zen Browser profile to: $PROFILE_DIR"
log -i "From archive: $BACKUP_FILE ($(human_size "$BACKUP_FILE"))"

log -w "This will overwrite existing files in $PROFILE_DIR"
echo -n "Continue? [y/N] "
read -r CONFIRM
if [[ "$CONFIRM" != "y" && "$CONFIRM" != "Y" ]]; then
    log -i "Restore cancelled."
    exit 0
fi

tar -xzf "$BACKUP_FILE" -C "$(dirname "$PROFILE_DIR")"

log -s "Restore completed to: $PROFILE_DIR"
log -i "It is recommended to:"
log -i "  1. Run 'zen --safe-mode' once to let Zen perform any migrations"
log -i "  2. Then restart Zen normally"
