#!/usr/bin/env zsh
#
# git-set-me - Set git user config for current repo
#
# Configures user.name and user.email in the current
# repository's local git config.
#
# Usage:
#   git-set-me

set -euo pipefail

log -i "Setting up git user configuration to: Petr Fusek | petr.fusek97@gmail.com"

git config user.name "Petr Fusek"
git config user.email petr.fusek97@gmail.com

log -i "Completed git user configuration setup."
