#!/usr/bin/env zsh
# Runs a command and appends its timestamped output to ~/.local/state/niri/logs/<cmd>.log
# Usage: niri-log-wrapper <command> [args...]

source "$HOME/.zshrc"
source "$SCRIPT_FNS/log.zsh"

LOG_DIR="$HOME/.local/state/niri/logs"
mkdir -p "$LOG_DIR"

CMD_NAME="$(basename "$1")"
LOG_FILE="$LOG_DIR/${CMD_NAME}.log"

# Clean up old log file if it exists
echo -n "" > "$LOG_FILE"

"$@" 2>&1 | while IFS= read -r line; do
    log -i -f "$LOG_FILE" -- "$line"
done

log -i -f "$LOG_FILE" -- "Finished running: $*"
