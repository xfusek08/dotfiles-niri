#!/usr/bin/env zsh
#
# nrs - NixOS Rebuild Switch
#
# Runs nixos-rebuild switch.
# Any arguments are forwarded to nixos-rebuild.
#
# Usage:
#   nrs              # update + backup + rebuild
#   nrs --upgrade    # same (also passed to nixos-rebuild)

set -euo pipefail

sudo nixos-rebuild switch --flake "$NIXOS_CONFIG#nixos" "$@"
